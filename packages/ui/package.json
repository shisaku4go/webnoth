{
  "name": "@webnoth/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "development": "./src/index.ts",
      "default": "./dist/index.js"
    },
    "./components/*": {
      "types": "./src/components/*.tsx",
      "development": "./src/components/*.tsx",
      "default": "./dist/components/*.js"
    },
    "./lib/*": {
      "types": "./src/lib/*.ts",
      "development": "./src/lib/*.ts",
      "default": "./dist/lib/*.js"
    },
    "./hooks/*": {
      "types": "./src/hooks/*.ts",
      "development": "./src/hooks/*.ts",
      "default": "./dist/hooks/*.js"
    },
    "./styles/*": "./src/styles/*"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest"
  },
  "peerDependencies": {
    "lucide-react": ">=0.400.0",
    "radix-ui": ">=1.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.14.0",
    "radix-ui": ">=1.1.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "@webnoth/config": "workspace:*",
    "jsdom": "^29.1.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwindcss": "^4.3.0",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "vite": "^8.0.12",
    "vitest": "^4.1.5"
  }
}
